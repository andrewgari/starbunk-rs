{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; [ -n \"$f\" ] && echo \"$f\" | grep -q '\\.rs$' && rustfmt \"$f\" 2>/dev/null; } 2>/dev/null || true",
            "statusMessage": "rustfmt"
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; [ -n \"$f\" ] && { echo \"$f\" | grep -q '\\.rs$' || [ \"$(basename \"$f\")\" = \"Cargo.toml\" ]; } && [ -f Cargo.toml ] && cargo check 2>&1 | tail -5; } 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Skill(update-config)",
      "Skill(task)",
      "Skill(deploy)",
      "Skill(review-pr-comments)",
      "Skill(health-check)",
      "Skill(ci-diagnose)",
      "Skill(build)",
      "Skill(check)",
      "Skill(test)",
      "Skill(lint)",
      "Skill(docker)",
      "Skill(logs)",
      "Skill(triage-issues)",
      "Bash(git:*)",
      "Bash(gh pr:*)",
      "Bash(gh api:*)",
      "Bash(gh run:*)",
      "Bash(gh workflow:*)",
      "Bash(gh issue:*)",
      "Bash(cargo build:*)",
      "Bash(cargo check:*)",
      "Bash(cargo test:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo run:*)",
      "Bash(docker compose:*)",
      "Bash(docker:*)",
      "Bash(bash scripts/devops-validate.sh)",
      "Bash(bash scripts/devops-validate.sh:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(chmod +x:*)",
      "Bash(mkdir -p:*)",
      "Bash(touch:*)",
      "Bash(ssh tower:*)",
      "Bash(tower:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:discord.com)",
      "WebFetch(domain:docs.discord.com)"
    ]
  }
}
