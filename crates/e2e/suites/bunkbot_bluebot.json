{
  "tests": [
    {
      "name": "Bunkbot ping response",
      "sender": "human",
      "message": "ping bunkbot",
      "expect": "Pong from bunkbot!",
      "timeout_ms": 2500
    },
    {
      "name": "Bunkbot ignores bot pings",
      "sender": "bot",
      "message": "ping bunkbot",
      "expect_no_response": true,
      "timeout_ms": 2500
    },
    {
      "name": "Bluebot trigger on 'blue'",
      "sender": "human",
      "message": "Did somebody say blue?",
      "expect": "Did somebody say Blu?",
      "timeout_ms": 2500
    },
    {
      "name": "Bluebot ignores bot trigger",
      "sender": "bot",
      "message": "Did somebody say blue?",
      "expect_no_response": true,
      "timeout_ms": 2500
    },
    {
      "name": "Bluebot word boundary trigger failure",
      "sender": "human",
      "message": "This bluetooth speaker is great",
      "expect_no_response": true,
      "timeout_ms": 2500
    },
    {
      "name": "Bluebot reply confirm triggers on short confirmation",
      "sender": "human",
      "message": "yes",
      "expect": "Somebody definitely said Blu!",
      "timeout_ms": 2500
    },
    {
      "name": "Bluebot request confirm triggers on nice request",
      "sender": "human",
      "message": "bluebot, say something nice about me",
      "expect": "<@human>, I think you're pretty blue! :wink:",
      "timeout_ms": 2500
    },
    {
      "name": "Bluebot request confirm enemy triggers on enemy request",
      "sender": "human",
      "message": "bluebot, say something nice about theenemy",
      "expect": "No way, they can suck my blue cane :unamused:",
      "timeout_ms": 2500
    }
  ]
}
