    },
    {
      "name": "baby-bot silent on 'infant'",
      "sender": "human",
      "message": "look at this cute infant",
      "expect_no_response": true,
      "timeout_ms": 2500
    },
    {
      "name": "chaos-bot triggers on 'chaos'",
      "sender": "human",
