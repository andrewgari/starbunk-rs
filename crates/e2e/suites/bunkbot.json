      "message": "I love building robot models",
      "expect_no_response": true,
      "timeout_ms": 2500
    },
    {
      "name": "venn-bot triggers on 'cringe'",
      "sender": "human",
      "message": "that was so cringe",
      "expect": "cringe",
      "timeout_ms": 2500
    },
    {
      "name": "venn-bot silent on 'based'",
      "sender": "human",
      "message": "that was so based",
      "expect_no_response": true,
      "timeout_ms": 2500
    },
    {
      "name": "check-bot triggers on 'check' and responds with czech",
      "sender": "human",
      "message": "check your email",
      "expect": "czech",
      "timeout_ms": 2500
    },
    {
      "name": "check-bot triggers on 'czech' and responds with check",
      "sender": "human",
      "message": "the czech republic is lovely",
      "expect": "check",
      "timeout_ms": 2500
    },
    {
      "name": "check-bot silent on 'checkout' (partial word)",
      "sender": "human",
      "message": "go to the checkout counter",
      "expect_no_response": true,
      "timeout_ms": 2500
    },
    {
      "name": "ezio-bot triggers on 'assassin'",
      "sender": "human",
      "message": "he is an assassin",
      "expect": "Nothing is true",
      "timeout_ms": 2500
    },
    {
      "name": "ezio-bot triggers on 'ezio'",
      "sender": "human",
      "message": "my favourite character is ezio",
      "expect": "Everything is permitted",
      "timeout_ms": 2500
    },
    {
      "name": "ezio-bot silent on 'hitman'",
      "sender": "human",
      "message": "he is a hitman",
      "expect_no_response": true,
      "timeout_ms": 2500
    },
    {
      "name": "guy-bot triggers on 'guy' in message",
      "sender": "human",
      "message": "that guy is hilarious",
      "expect_any_response": true,
      "timeout_ms": 2500
    },
    {
      "name": "guy-bot silent on unrelated message",
      "sender": "human",
      "message": "that person is hilarious",
      "expect_no_response": true,
      "timeout_ms": 2500
    },
    {
      "name": "botbot responds only to bots (not humans)",
      "sender": "human",
      "message": "hello fellow bot",
      "expect_no_response": true,
      "timeout_ms": 2500
    },
    {
      "name": "interrupt-bot does not trigger on empty message",
      "sender": "human",
      "message": "   ",
      "expect_no_response": true,
      "timeout_ms": 2500
    }
  ]
}
