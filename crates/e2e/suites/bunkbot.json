{
  "tests": [
    {
      "name": "banana-bot triggers on 'banana'",
      "sender": "human",
      "message": "I love eating banana bread",
      "expect": "banana",
      "timeout_ms": 2500
    },
    {
      "name": "banana-bot silent on unrelated message",
      "sender": "human",
      "message": "I love eating apple bread",
      "expect_no_response": true,
      "timeout_ms": 2500
    },
    {
      "name": "clanker-bot triggers on 'clanker'",
      "sender": "human",
      "message": "you clanker!",
      "expect": "meatbag",
      "timeout_ms": 2500
    },
    {
      "name": "clanker-bot silent on 'droid'",
      "sender": "human",
      "message": "these droids are no match for me",
      "expect_no_response": true,
      "timeout_ms": 2500
    },
    {
      "name": "spider-bot triggers on 'spiderman' (no hyphen)",
      "sender": "human",
      "message": "spiderman is my favourite hero",
      "expect": "Spider-Man",
      "timeout_ms": 2500
    },
    {
      "name": "spider-bot silent when hyphen is present",
      "sender": "human",
      "message": "Spider-Man is my favourite hero",
      "expect_no_response": true,
      "timeout_ms": 2500
    },
    {
      "name": "nice-bot triggers on 69",
      "sender": "human",
      "message": "I scored 69 points",
      "expect": "Nice",
      "timeout_ms": 2500
    },
    {
      "name": "nice-bot triggers on 'sixty-nine'",
      "sender": "human",
      "message": "I'm sixty-nine years old",
      "expect": "Nice",
      "timeout_ms": 2500
    },
    {
      "name": "nice-bot silent on 68",
      "sender": "human",
      "message": "I scored 68 points",
      "expect_no_response": true,
      "timeout_ms": 2500
    },
    {
      "name": "sheesh-bot triggers on 'sheeeesh'",
      "sender": "human",
      "message": "sheeeesh that was amazing",
      "expect": "sh",
      "timeout_ms": 2500
    },
    {
      "name": "sheesh-bot triggers on minimal 'sheesh'",
      "sender": "human",
      "message": "sheesh",
      "expect": "sh",
      "timeout_ms": 2500
    },
    {
      "name": "sheesh-bot silent on 'shesh' (only one e)",
      "sender": "human",
      "message": "shesh that was odd",
      "expect_no_response": true,
      "timeout_ms": 2500
    },
    {
      "name": "pickle-bot triggers on 'gremlin'",
      "sender": "human",
      "message": "stop acting like a gremlin",
      "expect": "gremlin",
      "timeout_ms": 2500
    },
    {
      "name": "pickle-bot silent on 'goblin'",
      "sender": "human",
      "message": "stop acting like a goblin",
      "expect_no_response": true,
      "timeout_ms": 2500
    },
    {
      "name": "hold-bot triggers on exact 'Hold'",
      "sender": "human",
      "message": "Hold",
      "expect": "Hold.",
      "timeout_ms": 2500
    },
    {
      "name": "hold-bot triggers on 'Hold.' with period",
      "sender": "human",
      "message": "Hold.",
      "expect": "Hold.",
      "timeout_ms": 2500
    },
    {
      "name": "hold-bot silent on 'Hold on' (not full message)",
      "sender": "human",
      "message": "Hold on a second",
      "expect_no_response": true,
      "timeout_ms": 2500
    },
    {
      "name": "attitude-bot triggers on \"you can't\"",
      "sender": "human",
      "message": "you can't do that",
      "expect": "attitude",
      "timeout_ms": 2500
    },
    {
      "name": "attitude-bot triggers on \"I can't\"",
      "sender": "human",
      "message": "I can't believe it",
      "expect": "attitude",
      "timeout_ms": 2500
    },
    {
      "name": "attitude-bot silent on 'you can do that'",
      "sender": "human",
      "message": "you can do anything",
      "expect_no_response": true,
      "timeout_ms": 2500
    },
    {
      "name": "baby-bot triggers on 'baby'",
      "sender": "human",
      "message": "look at this cute baby",
