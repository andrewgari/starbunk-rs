# Shared Token Fallback (Used if individual bot tokens are not provided)
STARBUNK_TOKEN=your_token_here

# Individual Bot Tokens
DISCORD_TOKEN=
BLUEBOT_TOKEN=
BUNKBOT_TOKEN=
COVABOT_TOKEN=
DJCOVA_TOKEN=
RATBOT_TOKEN=

# Rust Logging
# Valid values: error, warn, info, debug, trace
# Use starbunk=debug for detailed bot-level logging
RUST_LOG=info

# LLM Providers Configuration
# Add credentials for any providers you plan to use
OPENAI_API_KEY=
OPENAI_BASE_URL=

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

GOOGLE_API_KEY=
GOOGLE_BASE_URL=

OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# LLM Tiers Assignment
# High Tier (Used for deep reasoning, complex generation)
LLM_TIER_HIGH_PROVIDER=anthropic
LLM_TIER_HIGH_MODEL=claude-3-5-sonnet-latest

# Medium Tier (Used for standard conversation, fast replies)
LLM_TIER_MEDIUM_PROVIDER=google
LLM_TIER_MEDIUM_MODEL=gemini-1.5-flash

# Low Tier (Used for embeddings, simple summarization, quick background tasks)
LLM_TIER_LOW_PROVIDER=openai
LLM_TIER_LOW_MODEL=text-embedding-3-small

# Database (required for CovaBot memory)
POSTGRES_USER=starbunk
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=starbunk_memory
DATABASE_URL=postgresql://starbunk:change_me_in_production@localhost:5432/starbunk_memory
