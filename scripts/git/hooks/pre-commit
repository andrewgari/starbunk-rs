#!/usr/bin/env bash
# Pre-commit hook: rustfmt auto-format + cargo clippy + cargo build
# Matches the CI linter exactly.
#
# Install:
#   bash scripts/install-hooks.sh
#
# Requires cargo (installed via mise: `mise use rust@stable`)

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# --- rustfmt (auto-format staged files) ---
STAGED_RS=$(git diff --cached --name-only --diff-filter=ACM | grep '\.rs$' || true)
if [ -n "$STAGED_RS" ]; then
    echo "→ rustfmt: auto-formatting staged files..."
    echo "$STAGED_RS" | xargs rustfmt
    echo "$STAGED_RS" | xargs git add
fi

# --- cargo clippy ---
if command -v cargo &>/dev/null; then
    echo "→ cargo clippy -- -D warnings"
    cargo clippy -- -D warnings || exit 1
else
    echo "⚠️  cargo not found — run: mise install"
    exit 1
fi

# --- cargo build ---
echo "→ cargo build --bins"
cargo build --bins || exit 1

echo "✅ pre-commit checks passed"
