#!/usr/bin/env bash
# post-merge hook — prune worktrees whose PRs are now merged or closed.
# Runs silently in dry-run mode; only removes when gh is available.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

if ! command -v gh &>/dev/null; then
    exit 0
fi

# Run cleanup in background so merge isn't delayed
(bash "$REPO_ROOT/scripts/cleanup-worktrees.sh" --apply &>/dev/null) &
