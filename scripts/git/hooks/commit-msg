#!/usr/bin/env python3
import sys
import re

def main():
    if len(sys.argv) < 2:
        print("Error: No commit message file path provided.")
        sys.exit(1)

    commit_msg_filepath = sys.argv[1]
    with open(commit_msg_filepath, 'r', encoding='utf-8') as f:
        lines = f.readlines()

    # Filter out comments (lines starting with #)
    cleaned_lines = [line for line in lines if not line.strip().startswith('#')]
    # Remove empty lines from the beginning
    while cleaned_lines and not cleaned_lines[0].strip():
        cleaned_lines.pop(0)

    if not cleaned_lines:
        print("Error: Commit message is empty.")
        sys.exit(1)

    header = cleaned_lines[0].rstrip('\n')
    if not header:
        print("Error: Commit message header is empty.")
        sys.exit(1)

    # Conventional commits regex pattern
    # Type list: feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert
    types = r"feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert"
    # Matches type with optional scope, then colon and space, then subject
    pattern = re.compile(rf"^({types})(\([a-zA-Z0-9_\-\/,]+\))?!?: (.*)$")

    match = pattern.match(header)
    if not match:
        print("Error: Invalid commit message format.")
        print(f"Header: '{header}'")
        print("\nCommit message must follow Conventional Commits format:")
        print("  <type>(<scope>): <subject>")
        print("\nTypes allowed:")
        print("  feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert")
        print("\nExample:")
        print("  feat(ratbot): add gift exchange matching logic")
        sys.exit(1)

    commit_type, scope, subject = match.groups()

    if len(header) > 72:
        print(f"Error: Commit message header is too long ({len(header)}/72 chars).")
        print(f"Header: '{header}'")
        sys.exit(1)

    # Validate subject (first letter should be lowercase, no trailing period)
    if not subject:
        print("Error: Commit message subject is empty.")
        sys.exit(1)

    # Check if subject starts with an uppercase letter
    if subject[0].isupper() and subject[0].isalpha():
        print(f"Error: Commit subject should not start with an uppercase letter: '{subject}'")
        print("Please start the subject with a lowercase letter.")
        sys.exit(1)

    if subject.endswith('.'):
        print(f"Error: Commit subject should not end with a period: '{subject}'")
        sys.exit(1)

    sys.exit(0)

if __name__ == '__main__':
    main()
